<Window x:Class="EasySaveGUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paramètres EasySave v3.0" Height="600" Width="600"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer>
        <StackPanel Margin="20">

            <TextBlock Text="Paramètres généraux" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <GroupBox Header="Interface" Margin="0,0,0,10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Langue :" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cmbLanguage">
                        <ComboBoxItem Content="English" Tag="en"/>
                        <ComboBoxItem Content="Français" Tag="fr"/>
                    </ComboBox>

                    <TextBlock Text="Format des logs :" Margin="0,10,0,2"/>
                    <ComboBox x:Name="cmbLogFormat">
                        <ComboBoxItem Content="JSON" Tag="Json"/>
                        <ComboBoxItem Content="XML" Tag="Xml"/>
                    </ComboBox>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Sécurité" Margin="0,0,0,10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Logiciel métier (process à surveiller) :" Margin="0,5,0,2"/>
                    <TextBox x:Name="txtBusinessSoftware"/>
                    <TextBlock Text="Exemple : calc, notepad" FontSize="10" Foreground="Gray"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Cryptage" Margin="0,0,0,10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Extensions à crypter (séparées par des virgules) :" Margin="0,5,0,2"/>
                    <TextBox x:Name="txtEncryptionExt"/>
                    <TextBlock Text="Exemple : .docx,.pdf,.xlsx" FontSize="10" Foreground="Gray"/>

                    <TextBlock Text="Clé de cryptage :" Margin="0,10,0,2"/>
                    <TextBox x:Name="txtCryptoKey"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Fichiers prioritaires (v3.0)" Margin="0,0,0,10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Extensions prioritaires (séparées par des virgules) :" Margin="0,5,0,2"/>
                    <TextBox x:Name="txtPriorityExt"/>
                    <TextBlock Text="Exemple : .docx,.pdf" FontSize="10" Foreground="Gray"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Bande passante (v3.0)" Margin="0,0,0,10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Taille max d'un fichier transféré en parallèle (Ko) :" Margin="0,5,0,2"/>
                    <TextBox x:Name="txtMaxFileSize"/>
                    <TextBlock Text="Les fichiers plus gros seront transférés un par un" FontSize="10" Foreground="Gray"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Logs Docker (v3.0)" Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <TextBlock Text="Mode de stockage des logs :" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cmbLogStorage">
                        <ComboBoxItem Content="Local seulement" Tag="Local"/>
                        <ComboBoxItem Content="Docker seulement" Tag="Docker"/>
                        <ComboBoxItem Content="Local + Docker" Tag="Both"/>
                    </ComboBox>

                    <TextBlock Text="URL du serveur Docker :" Margin="0,10,0,2"/>
                    <TextBox x:Name="txtDockerUrl"/>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annuler" Click="Cancel_Click" Padding="20,5" Margin="0,0,10,0"/>
                <Button Content="Enregistrer" Click="Save_Click" Padding="20,5" Background="#4CAF50" Foreground="White"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>