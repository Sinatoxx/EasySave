<Window x:Class="EasySaveGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EasySave" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Backup Jobs (Unlimited)" FontSize="18" FontWeight="Bold"/>
        <DataGrid ItemsSource="{Binding Jobs}" AutoGenerateColumns="True" Height="200"/>

        <Separator Margin="0,10"/>

        <TextBlock Text="Real-time Progress:"/>
        <ProgressBar Value="{Binding CurrentProgress}" Maximum="100" Height="25"/>
        <TextBlock Text="{Binding CurrentStatus}" HorizontalAlignment="Center"/>

        <Button Content="Execute All" Click="ExecuteAll_Click" Margin="0,10"/>
    </StackPanel>
</Window>
